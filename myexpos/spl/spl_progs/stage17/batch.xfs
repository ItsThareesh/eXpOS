fdisk
load --os $HOME/myexpos/spl/spl_progs/stage17/os_startup.xsm
load --library $HOME/myexpos/expl/library.lib
load --module 0 $HOME/myexpos/spl/spl_progs/stage17/MOD0.xsm
load --module 1 $HOME/myexpos/spl/spl_progs/stage17/MOD1.xsm
load --module 2 $HOME/myexpos/spl/spl_progs/stage17/MOD2.xsm
load --module 4 $HOME/myexpos/spl/spl_progs/stage17/MOD4.xsm
load --module 5 $HOME/myexpos/spl/spl_progs/stage17/scheduler.xsm
load --module 7 $HOME/myexpos/spl/spl_progs/stage17/boot_module.xsm
load --int=timer $HOME/myexpos/spl/spl_progs/stage17/TIMER.xsm
load --int=console $HOME/myexpos/spl/spl_progs/stage17/console.xsm
load --int=6 $HOME/myexpos/spl/spl_progs/stage17/INT6.xsm
load --int=7 $HOME/myexpos/spl/spl_progs/stage17/INT7.xsm
load --int=9 $HOME/myexpos/spl/spl_progs/stage17/INT9.xsm
load --int=10 $HOME/myexpos/spl/spl_progs/stage17/INT10.xsm
load --exhandler $HOME/myexpos/spl/spl_progs/stage17/EXHANDLER.xsm
load --idle $HOME/myexpos/expl/samples/idle.xsm
load --init $HOME/myexpos/expl/samples/stage17/shell.xsm
load --exec $HOME/myexpos/expl/samples/stage17/evennos.xsm
load --exec $HOME/myexpos/expl/samples/stage17/oddnos.xsm
load --exec $HOME/myexpos/expl/samples/stage17/bblsort.xsm