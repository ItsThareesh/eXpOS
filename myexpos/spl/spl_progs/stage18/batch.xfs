fdisk
load --os $HOME/myexpos/spl/spl_progs/stage18/os_startup.xsm
load --library $HOME/myexpos/expl/library.lib
load --module 0 $HOME/myexpos/spl/spl_progs/stage18/MOD0.xsm
load --module 1 $HOME/myexpos/spl/spl_progs/stage18/MOD1.xsm
load --module 2 $HOME/myexpos/spl/spl_progs/stage18/MOD2.xsm
load --module 4 $HOME/myexpos/spl/spl_progs/stage18/MOD4.xsm
load --module 5 $HOME/myexpos/spl/spl_progs/stage18/scheduler.xsm
load --module 7 $HOME/myexpos/spl/spl_progs/stage18/boot_module.xsm
load --int=timer $HOME/myexpos/spl/spl_progs/stage18/TIMER.xsm
load --int=console $HOME/myexpos/spl/spl_progs/stage18/console_interrupt.xsm
load --int=disk $HOME/myexpos/spl/spl_progs/stage18/disk_interrupt.xsm
load --int=6 $HOME/myexpos/spl/spl_progs/stage18/INT6.xsm
load --int=7 $HOME/myexpos/spl/spl_progs/stage18/INT7.xsm
load --int=9 $HOME/myexpos/spl/spl_progs/stage18/INT9.xsm
load --int=10 $HOME/myexpos/spl/spl_progs/stage18/INT10.xsm
