#!/bin/bash

# Configuration
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

BASE_DIR="$HOME/myexpos"
SPL_PROGS_DIR="$BASE_DIR/spl/spl_progs"
XFS_DIR="$BASE_DIR/xfs-interface"
XFS_EXEC="$XFS_DIR/xfs-interface"

usage() {
    echo -e "${YELLOW}Usage:${NC}"
    echo "  runxfs <stage_folder_or_file_path> [batch_file_name]"
    exit 2
}

# Accept either 1 or 2 arguments to support raw paths
if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
    usage
fi

INPUT_PATH="$1"
FILE_NAME="$2"

# Determine file path and stage info depending on whether a raw path or stage name was given
if [ -f "$INPUT_PATH" ]; then
    # User provided a direct path to a file
    FILE_PATH="$(cd "$(dirname "$INPUT_PATH")" && pwd)/$(basename "$INPUT_PATH")"
    STAGE_DIR="$(dirname "$FILE_PATH")"
    STAGE="$(basename "$STAGE_DIR")"
    FILE_NAME="$(basename "$FILE_PATH")"
elif [ -d "$INPUT_PATH" ] && [ -n "$FILE_NAME" ]; then
    # User provided a directory path and a file name
    STAGE_DIR="$(cd "$INPUT_PATH" && pwd)"
    STAGE="$(basename "$STAGE_DIR")"
    FILE_PATH="$STAGE_DIR/$FILE_NAME"
else
    # Fallback to legacy behavior: positional arguments as stage shorthand
    STAGE="$INPUT_PATH"
    STAGE_DIR="$SPL_PROGS_DIR/$STAGE"
    FILE_PATH="$STAGE_DIR/$FILE_NAME"
fi

# Structural Validations
if [ ! -d "$STAGE_DIR" ]; then
    echo -e "${RED}Error:${NC} Target stage directory does not exist or could not be resolved."
    exit 2
fi

if [ -z "$FILE_NAME" ] || [ ! -f "$FILE_PATH" ]; then
    echo -e "${RED}Error:${NC} Target file '$FILE_NAME' not found or path invalid."
    exit 2
fi

if [ ! -x "$XFS_EXEC" ]; then
    echo -e "${RED}Error:${NC} xfs-interface executable not found or permissions missing at '$XFS_EXEC'."
    exit 2
fi

echo "------------------------------------------------------------"
echo -e "${YELLOW}Stage:${NC}  $STAGE"
echo -e "${YELLOW}Target:${NC} $FILE_NAME"
echo -e "${YELLOW}Path:${NC}   $FILE_PATH"
echo "------------------------------------------------------------"

# Capture current working directory to return here at the end
ORIGINAL_PWD="$PWD"

# Shift to XFS Interface sandbox home
cd "$XFS_DIR" || exit 2

printf "%-45s" "Running: $FILE_NAME"

# Execute using the fully resolved absolute file path securely
OUTPUT=$("$XFS_EXEC" run "$FILE_PATH" 2>&1)
STATUS=$?

if [ "$STATUS" -ne 0 ]; then
    echo -e "[ ${RED}FAILED${NC} ]"
    echo "------------------------------------------------------------"
    echo -e "${RED}XFS execution failed with exit code $STATUS.${NC}"
    if [ -n "$OUTPUT" ]; then
        echo -e "Output Logs:\n$OUTPUT"
    fi
    cd "$ORIGINAL_PWD"
    exit 1
else
    echo -e "[ ${GREEN}OK${NC} ]"
    if [ -n "$OUTPUT" ]; then
        # Format interior logs lines neatly
        while IFS= read -r line; do
            echo -e " - ${GREEN}$line${NC}"
        done <<< "$OUTPUT"
    fi
fi

# Revert back to user's original directory context
cd "$ORIGINAL_PWD"

echo "------------------------------------------------------------"
echo -e "${GREEN}XFS execution completed safely.${NC}"
exit 0