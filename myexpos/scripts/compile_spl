#!/bin/bash

# Configuration
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

BASE_DIR="$HOME/myexpos"
SPL_DIR="$BASE_DIR/spl"
SPL_COMPILER="./spl"  # Must be run relatively inside $SPL_DIR

usage() {
    echo -e "${YELLOW}Usage:${NC}"
    echo "  compile_spl <stage_folder_or_directory_path> [file_name]"
    echo "  compile_spl --stage <stage_folder_or_directory_path> [--file <file_name>]"
    exit 2
}

# Parse named or positional arguments
INPUT_PATH=""
FILE_FILTER=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -s|--stage) INPUT_PATH="$2"; shift 2 ;;
        -f|--file)  FILE_FILTER="$2"; shift 2 ;;
        -h|--help)  usage ;;
        -*)         echo -e "${RED}Unknown option:${NC} $1"; usage ;;
        *) 
            if [ -z "$INPUT_PATH" ]; then
                INPUT_PATH="$1"
            elif [ -z "$FILE_FILTER" ]; then
                FILE_FILTER="$1"
            else
                usage
            fi
            shift
            ;;
    esac
done

if [ -z "$INPUT_PATH" ]; then
    usage
fi

# Clean up FILE_FILTER to strip out the .spl extension internally for uniform logic
if [ -n "$FILE_FILTER" ]; then
    FILE_FILTER=$(basename "$FILE_FILTER" .spl)
fi

# Determine Target Directory
if [ -d "$INPUT_PATH" ]; then
    TARGET_DIR="$(cd "$INPUT_PATH" && pwd)"
else
    TARGET_DIR="$SPL_DIR/spl_progs/$INPUT_PATH"
fi

# Environment Validation
if [ ! -d "$TARGET_DIR" ]; then
    echo -e "${RED}Error:${NC} Target directory '$INPUT_PATH' does not exist."
    exit 2
fi

if [ -n "$FILE_FILTER" ] && [ ! -f "$TARGET_DIR/$FILE_FILTER.spl" ]; then
    echo -e "${RED}Error:${NC} File '$FILE_FILTER.spl' not found in target directory."
    exit 2
fi

# Build Mode Display
echo "------------------------------------------------------------"
if [ -n "$FILE_FILTER" ]; then
    echo -e "${BLUE}Build Mode:${NC} Single file"
    echo -e "${YELLOW}Target:${NC}     $FILE_FILTER.spl"
else
    echo -e "${BLUE}Build Mode:${NC} Full Directory/Stage"
    echo -e "${YELLOW}Path:${NC}       $TARGET_DIR"
fi
echo "------------------------------------------------------------"

total=0
success=0
failed=0
failed_files=()

shopt -s nullglob

# Capture current working directory to return here at the end
ORIGINAL_PWD="$PWD"

# Shift context to $SPL_DIR
if ! cd "$SPL_DIR"; then
    echo -e "${RED}Error:${NC} Could not navigate to '$SPL_DIR'."
    exit 1
fi

if [ ! -x "$SPL_COMPILER" ]; then
    echo -e "${RED}Error:${NC} SPL compiler executable not found at '$SPL_DIR/spl'."
    cd "$ORIGINAL_PWD"
    exit 1
fi

for file in "$TARGET_DIR"/*.spl; do
    fname=$(basename "$file" .spl)

    if [ -n "$FILE_FILTER" ] && [ "$FILE_FILTER" != "$fname" ]; then
        continue
    fi

    total=$((total + 1))
    printf "%-45s" "Compiling: $fname.spl"

    # Pass the absolute path to the file so the compiler resolves it accurately from inside $SPL_DIR
    output=$($SPL_COMPILER "$TARGET_DIR/$fname.spl" 2>&1)
    exit_code=$?

    # Check both exit codes and look for internal compiler error notifications
    if [ $exit_code -ne 0 ] || [ -n "$output" ]; then
        echo -e "[ ${RED}FAILED${NC} ]"
        
        if [ -n "$output" ]; then
            while IFS= read -r line; do
                echo "    $line"
            done <<< "$output"
        fi
        
        failed=$((failed + 1))
        failed_files+=("$fname.spl")
    else
        echo -e "[ ${GREEN}OK${NC} ]"
        success=$((success + 1))
    fi
done

cd "$ORIGINAL_PWD"

echo "------------------------------------------------------------"

if [ "$total" -eq 0 ]; then
    echo -e "${YELLOW}No .spl files found to compile in '$TARGET_DIR'.${NC}"
    exit 1
fi

# Final Summary Report
echo -e "${BLUE}Summary:${NC}"
echo -e " - Total   : $total"
echo -e " - Success : ${GREEN}$success${NC}"
echo -e " - Failed  : ${RED}$failed${NC}"

if [ "$failed" -ne 0 ]; then
    echo
    echo -e "${RED}Failed Files:${NC}"
    for f in "${failed_files[@]}"; do
        echo -e " - $f"
    done
    exit 1
fi

echo
echo -e "${GREEN}Build completed successfully.${NC}"
exit 0