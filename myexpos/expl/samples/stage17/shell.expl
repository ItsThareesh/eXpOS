int main() {
    decl
        int temp;
        str programName;
    enddecl
    begin
        temp = exposcall("Write", -2, ">");
        temp = exposcall("Read", -1, programName);
        breakpoint;

        temp = exposcall("Exec", programName);
        
        if (temp != 0) then
            temp = exposcall("Write", -2, "Invalid File");
        endif;

        return 0;
    end
}