int main() {
    decl 
        str fileName;
        int temp;
    enddecl

    begin 
        temp = exposcall("Write", -2, "rm file?");
        temp = exposcall("Read", -1, fileName);
        temp = exposcall("Delete", fileName);
        
        if (temp == 0) then
            temp = exposcall("Write", -2, "File Deleted");
        else
            temp = exposcall("Write", -2, temp);
            temp = exposcall("Write", -2, "EC No.");
        endif;

        return 0;
    end
}